{
  "name": "pbi-agent-docs",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "scripts": {
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "lint": "eslint webapp/src webapp/vite.config.ts",
    "lint:fix": "bun run lint -- --fix",
    "test:web": "vitest run --config webapp/vitest.config.ts",
    "test:web:watch": "vitest --config webapp/vitest.config.ts",
    "test:web:coverage": "vitest run --coverage --config webapp/vitest.config.ts",
    "typecheck": "tsc -p webapp/tsconfig.json --noEmit",
    "web:dev": "vite --config webapp/vite.config.ts",
    "web:build": "vite build --config webapp/vite.config.ts",
    "web:preview": "vite preview --config webapp/vite.config.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@tanstack/react-query": "^5.95.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.11.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.2",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.5.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.0",
    "globals": "^16.5.0",
    "jsdom": "^27.1.0",
    "semver": "^7.7.3",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.46.2",
    "vite": "^8.0.3",
    "vitepress": "^1.6.4",
    "vitest": "^3.2.4"
  }
}
