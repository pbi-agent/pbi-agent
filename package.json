{
  "name": "pbi-agent-docs",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "scripts": {
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "lint": "eslint webapp/src webapp/vite.config.ts",
    "lint:fix": "bun run lint -- --fix",
    "typecheck": "tsc -p webapp/tsconfig.json --noEmit",
    "web:dev": "vite --config webapp/vite.config.ts",
    "web:build": "vite build --config webapp/vite.config.ts",
    "web:preview": "vite preview --config webapp/vite.config.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@tanstack/react-query": "^5.95.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.0",
    "globals": "^16.5.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.46.2",
    "vite": "^8.0.3",
    "vitepress": "^1.6.4"
  }
}
