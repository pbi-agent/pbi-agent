{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "ignoreDeprecations": "6.0",
    "isolatedModules": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["vite/client", "node", "react", "react-dom", "vitest/globals", "@testing-library/jest-dom/vitest"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["./src", "./vite.config.ts"]
}
